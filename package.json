{
  "name": "navigator-frontend",
  "private": true,
  "scripts": {
    "dev": "next",
    "build": "next build",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "start": "next start",
    "prod": "next build && next start",
    "type-check": "tsc",
    "tsc": "tsc",
    "add": "docker-compose exec -w /opt/node_app frontend npm install -S",
    "add-dev": "docker-compose exec -w /opt/node_app frontend npm install -D",
    "remove": "docker-compose exec -w /opt/node_app frontend npm uninstall",
    "test": "vitest",
    "test-list": "vitest list",
    "test-e2e": "npx playwright test",
    "test-e2e-ui": "npx playwright test --ui",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "analyze": "THEME=cpr next experimental-analyze",
    "size": "npx size-limit"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
