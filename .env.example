APP_URL=http://localhost:3000

# @related: GITHUB_SHA_ENV_VAR
GITHUB_SHA=local

# OpenTelemetry
# The URL of your Faro instance, can be found in the Grafana Cloud UI
NEXT_PUBLIC_FARO_URL=https://faro-collector-prod-gb-south-0.grafana.net/collect/74f6d4bd78b7bb2cc270036193aaa3a6
NEXT_PUBLIC_FARO_APP_NAME=cpr-frontend
NEXT_PUBLIC_FARO_APP_NAMESPACE=frontend

# Next App BACKEND Instrumentation
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.staging.climatepolicyradar.org/
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SERVICE_NAME=frontend-server
# Customize resource attributes, namespace is a recommended attribute, here we set it to the same value as the frontend namespace to enable correlation
OTEL_RESOURCE_ATTRIBUTES=service.namespace=frontend
